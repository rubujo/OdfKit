<?xml version="1.0" encoding="UTF-8"?>
<office:document xmlns:office="urn:oasis:names:tc:opendocument:xmlns:office:1.0" xmlns:style="urn:oasis:names:tc:opendocument:xmlns:style:1.0" xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0" office:version="1.4" office:mimetype="application/vnd.oasis.opendocument.text">
  <office:automatic-styles>
    <style:page-layout style:name="pm1">
      <style:page-layout-properties>
        <style:columns fo:column-count="2"/>
        <style:columns fo:column-count="3"/>
      </style:page-layout-properties>
    </style:page-layout>
  </office:automatic-styles>
  <office:body>
    <office:text/>
  </office:body>
</office:document>
